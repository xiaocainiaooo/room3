- description: Initial State
  command: Capture
  result:
    type: CoreDocument
    width: 1000
    height: 1000
    operations:
    - type: RootLayoutComponent
      id: -2
      x: 0.0
      y: 0.0
      width: 1000.0
      height: 1000.0
      visibility: VISIBLE
      list:
      - type: FLOW
        id: -3
        x: 0.0
        y: 0.0
        width: 1000.0
        height: 70.0
        visibility: VISIBLE
        list:
        - type: ComponentModifiers
          modifiers:
          - type: WidthModifierOperation
            width: {type: Variable, id: 0, value: !!float 'NaN'}
            dimensionModifierType: FILL
          - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 1000.0, height: 70.0,
            color: '0xffaaaaaa', shapeType: RECTANGLE}
          - {type: PaddingModifierOperation, left: 10.0, top: 10.0, right: 10.0, bottom: 10.0}
        - type: BOX
          id: -5
          x: 0.0
          y: 0.0
          width: 50.0
          height: 50.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 50.0, height: 50.0,
              color: '0xffff0000', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: CENTER
          horizontalPositioning: CENTER
        - type: BOX
          id: -6
          x: 60.0
          y: 0.0
          width: 50.0
          height: 50.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 50.0, height: 50.0,
              color: '0xff00ff00', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: CENTER
          horizontalPositioning: CENTER
        - type: BOX
          id: -7
          x: 120.0
          y: 0.0
          width: 50.0
          height: 50.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 50.0, height: 50.0,
              color: '0xff0000ff', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: CENTER
          horizontalPositioning: CENTER
        paddingLeft: 10.0
        paddingRight: 10.0
        paddingTop: 10.0
        paddingBottom: 10.0
        verticalPositioning: TOP
        horizontalPositioning: START
        spacedBy: 10.0
