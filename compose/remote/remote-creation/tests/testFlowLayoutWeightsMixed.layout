- description: Initial State
  command: Capture
  result:
    type: CoreDocument
    width: 1000
    height: 1000
    operations:
    - type: RootLayoutComponent
      id: -2
      x: 0.0
      y: 0.0
      width: 1000.0
      height: 1000.0
      visibility: VISIBLE
      list:
      - type: ROW
        id: -3
        x: 0.0
        y: 0.0
        width: 1000.0
        height: 66.0
        visibility: VISIBLE
        list:
        - type: ComponentModifiers
          modifiers:
          - type: WidthModifierOperation
            width: {type: Value, value: 600.0}
            dimensionModifierType: EXACT
          - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 1000.0, height: 66.0,
            color: '0xffffff00', shapeType: RECTANGLE}
          - {type: PaddingModifierOperation, left: 8.0, top: 8.0, right: 8.0, bottom: 8.0}
        - type: BOX
          id: -5
          x: 0.0
          y: 0.0
          width: 100.0
          height: 50.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
