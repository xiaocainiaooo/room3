              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 100.0, height: 50.0,
              color: '0xffff0000', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: CENTER
          horizontalPositioning: CENTER
        - type: BOX
          id: -6
          x: 100.0
          y: 0.0
          width: 784.0
          height: 50.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 1.0}
              dimensionModifierType: WEIGHT
            - type: HeightModifierOperation
              height: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 784.0, height: 50.0,
              color: '0xff00ff00', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: CENTER
          horizontalPositioning: CENTER
        - type: BOX
          id: -7
          x: 884.0
          y: 0.0
          width: 100.0
          height: 50.0
          visibility: VISIBLE
          list:
          - type: ComponentModifiers
            modifiers:
            - type: WidthModifierOperation
              width: {type: Value, value: 100.0}
              dimensionModifierType: EXACT
            - type: HeightModifierOperation
              height: {type: Value, value: 50.0}
              dimensionModifierType: EXACT
            - {type: BackgroundModifierOperation, x: 0.0, y: 0.0, width: 100.0, height: 50.0,
              color: '0xff0000ff', shapeType: RECTANGLE}
          paddingLeft: 0.0
          paddingRight: 0.0
          paddingTop: 0.0
          paddingBottom: 0.0
          verticalPositioning: CENTER
          horizontalPositioning: CENTER
        paddingLeft: 8.0
