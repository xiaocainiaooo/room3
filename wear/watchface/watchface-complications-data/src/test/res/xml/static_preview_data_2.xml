<complications>
    <complication type="SHORT_TEXT">
        <text>
            <formatted format="@string/formatted_text_of_2">
                <param><plain value="10" valueType="integer"/></param>
                <param><time instant="1735699200" /></param>
            </formatted>
        </text>
    </complication>

    <complication type="RANGED_VALUE" value="50" min="0" max="100">
        <title>
            <plain value="@integer/test_integer" valueType="integer"/>
        </title>
    </complication>

    <complication type="SHORT_TEXT">
        <text>
            <plain value="Valid" invalidAttr="should be ignored"/>
        </text>
    </complication>

    <complication type="LONG_TEXT">
        <text>
            <date instant="1735699200" formats="MMMd,MMd,Md" fallback="d/MM"/>
        </text>
        <title>
            <time instant="3661" shouldShortenAmPm="true"/> <!-- 01:01:01 GMT -->
        </title>
    </complication>
</complications>
