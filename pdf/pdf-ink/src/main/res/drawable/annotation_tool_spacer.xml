<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- This shape is transparent. Its only purpose is to occupy space. -->
    <solid android:color="@android:color/transparent" />
    <!--
      Define the size of the space. We'll use 4dp, which matches your
      existing marginEnd. This size will be used for both width (in horizontal)
      and height (in vertical).
    -->
    <size
        android:width="@dimen/margin_4dp"
        android:height="@dimen/margin_4dp" />
</shape>